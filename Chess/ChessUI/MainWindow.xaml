<Window x:Class="ChessUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ChessUI"
        mc:Ignorable="d"
        Title="Chess"
        Width="920" Height="660"
        MinWidth="640" MinHeight="480"
        Icon="Assets/icon.ico"
        WindowStartupLocation="CenterScreen"
        Background="#101010"
        KeyDown="Window_KeyDown">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="30"/>   <!-- Evaluation bar -->
            <ColumnDefinition Width="*"/>    <!-- Board (grows with window) -->
            <ColumnDefinition Width="260"/>  <!-- Sidebar (fixed) -->
        </Grid.ColumnDefinitions>

        <!-- Evaluation Bar -->
        <Border x:Name="EvalBarOuter"
                Grid.Column="0"
                Margin="4,0,4,0"
                Background="#2c2c2c"
                VerticalAlignment="Center">
            <Grid>
                <!-- White advantage portion — grows upward from the bottom -->
                <Border x:Name="EvalWhitePortion"
                        Background="#f0f0f0"
                        VerticalAlignment="Bottom"
                        Height="0"/>

                <!-- Score label — centered, rotated 90° -->
                <TextBlock x:Name="EvalScoreText"
                           Text="0.0"
                           Foreground="#777777"
                           FontSize="8"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           IsHitTestVisible="False">
                    <TextBlock.LayoutTransform>
                        <RotateTransform Angle="-90"/>
                    </TextBlock.LayoutTransform>
                </TextBlock>
            </Grid>
        </Border>

        <!-- Board (Viewbox scales the 600×600 content to fill available space) -->
        <Viewbox x:Name="BoardViewbox"
                 Grid.Column="1"
                 Stretch="Uniform"
                 SizeChanged="BoardViewbox_SizeChanged">
            <Grid x:Name="BoardGrid"
                  Width="600"
                  Height="600"
                  MouseDown="BoardGrid_MouseDown">
                <Grid.Background>
                    <ImageBrush ImageSource="Assets/Board.png" />
                </Grid.Background>

                <UniformGrid x:Name="HighlightGrid"
                             Rows="8"
                             Columns="8"/>

                <UniformGrid x:Name="PieceGrid"
                             Rows="8"
                             Columns="8"
                             RenderOptions.BitmapScalingMode="HighQuality"/>

                <ContentControl x:Name="MenuContainer"/>
            </Grid>
        </Viewbox>

        <!-- Sidebar -->
        <Grid Grid.Column="2" Background="#1a1a1a">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Status area -->
            <StackPanel Grid.Row="0" Margin="12,16,12,8">
                <TextBlock x:Name="PlayerTurnText"
                           Text="White to move"
                           Foreground="White"
                           FontSize="15"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,3"/>
                <TextBlock x:Name="GameModeText"
                           Text="Human vs Human"
                           Foreground="#888888"
                           FontSize="12"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10"/>
                <Rectangle Height="1" Fill="#333333" Margin="0,0,0,8"/>
                <TextBlock Text="Move History"
                           Foreground="#aaaaaa"
                           FontSize="12"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Move history list -->
            <ListBox x:Name="MoveHistoryList"
                     Grid.Row="1"
                     Background="Transparent"
                     BorderThickness="0"
                     Margin="4,0,4,0"
                     Foreground="#dddddd"
                     FontFamily="Consolas"
                     FontSize="13"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     VirtualizingPanel.ScrollUnit="Pixel">
                <ListBox.Resources>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Padding" Value="6,2"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.Resources>
            </ListBox>

            <!-- Control buttons -->
            <StackPanel Grid.Row="2" Margin="10,8,10,14">
                <Button x:Name="UndoButton"
                        Content="↩  Undo"
                        Style="{StaticResource SidebarButtonStyle}"
                        Margin="0,0,0,6"
                        Click="Undo_Click"/>
                <Button Content="💾  Save"
                        Style="{StaticResource SidebarButtonStyle}"
                        Margin="0,0,0,6"
                        Click="Save_Click"/>
                <Button Content="📂  Load"
                        Style="{StaticResource SidebarButtonStyle}"
                        Click="Load_Click"/>
                <TextBlock Text="F11 — Fullscreen"
                           Foreground="#444444"
                           FontSize="10"
                           HorizontalAlignment="Center"
                           Margin="0,10,0,0"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
