<UserControl x:Class="ChessUI.ModeMenu"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource BorderStyle}" Margin="60">
        <StackPanel Margin="30,40">
            <TextBlock Text="Chess" Style="{StaticResource TextStyle}" FontSize="52" FontWeight="Bold"
                       Margin="0,0,0,6"/>
            <TextBlock Text="Select Game Mode" Style="{StaticResource TextStyle}" FontSize="18"
                       Margin="0,0,0,36"/>

            <Button Content="2 Players"
                    Style="{StaticResource ButtonStyle}"
                    FontSize="16" Padding="0,12"
                    Margin="0,0,0,12"
                    Click="TwoPlayers_Click"/>

            <Button Content="vs Computer"
                    Style="{StaticResource ButtonStyle}"
                    FontSize="16" Padding="0,12"
                    Click="VsComputer_Click"/>
        </StackPanel>
    </Border>
</UserControl>
